{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "heroku.buildpacks",
    "buildpacks": [
      "heroku-community/apt",
      "heroku/php"
    ]
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 10,
    "startCommand": "vendor/bin/heroku-php-apache2 public/"
  }
}
